# Local/deployed backend resolver configuration.
# Values are injected by CDK for deployed Lambda functions.

AWS_REGION=us-east-1
SHAKE2_MULTIPLAYER_TABLE_NAME=shake2-dev-multiplayer
SHAKE2_ROOM_GAME_ID_INDEX_NAME=GameIdIndex

# Optional deployed-stack smoke test configuration.
SHAKE2_SMOKE_STACK_NAME=shake2-dev-multiplayer-infra
SHAKE2_SMOKE_EMAIL=smoke@example.com
SHAKE2_SMOKE_USERNAME=smoke-user
SHAKE2_SMOKE_PASSWORD=replace-with-a-temporary-password
SHAKE2_SMOKE_CREATE_USER=false
SHAKE2_SMOKE_GAME_ID=smoke-missing-game
SHAKE2_SMOKE_SEED_GAME=false
SHAKE2_SMOKE_SEEDED_GAME_ID=
SHAKE2_SMOKE_SECONDARY_EMAIL=smoke-nonmember@example.com
SHAKE2_SMOKE_SECONDARY_USERNAME=smoke-nonmember-user
SHAKE2_SMOKE_SECONDARY_PASSWORD=replace-with-a-temporary-password
