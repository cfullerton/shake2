# Public Expo values for multiplayer development. These identifiers are not
# secrets, but real local `.env` files should stay uncommitted.
EXPO_PUBLIC_SHAKE2_AWS_REGION=us-east-1
EXPO_PUBLIC_SHAKE2_APPSYNC_GRAPHQL_URL=https://example.appsync-api.us-east-1.amazonaws.com/graphql
EXPO_PUBLIC_SHAKE2_COGNITO_USER_POOL_ID=us-east-1_example
EXPO_PUBLIC_SHAKE2_COGNITO_USER_POOL_CLIENT_ID=exampleclientid

# Optional. If omitted, the app derives this from the GraphQL URL.
# EXPO_PUBLIC_SHAKE2_APPSYNC_REALTIME_URL=wss://example.appsync-realtime-api.us-east-1.amazonaws.com/graphql
