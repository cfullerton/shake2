{
  "name": "shake2",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "npm run start -w @shake2/mobile",
    "android": "npm run android -w @shake2/mobile",
    "ios": "npm run ios -w @shake2/mobile",
    "web": "npm run web -w @shake2/mobile",
    "test": "npm run test -w @shake2/game-engine",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  }
}
